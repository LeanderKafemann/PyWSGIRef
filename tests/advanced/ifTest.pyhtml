<{{evalPyHTML}}><title>Hello World</title>
		<{{evalPyHTML-modernStyling: true}}>
	</head>
	<body>
		<h1>Hello World</h1>
		<p>
		    This is a test whether Python evaluation with <b>if and else</b> works in PyHTML files.<br/>
			The test is successful if you see the time formatted the following:<br/>
			<li>bold if the current second is even</li><br/>
			<li>italic if the current second is odd</li><br/>

			<{{evalPyHTML-if: datetime.datetime.now().second%2==0}}><b><{{evalPyHTML-else}}><i><{{evalPyHTML-endif}}>
				<{{evalPyHTML-eval: str(datetime.datetime.now()) :eval-}}>
			<{{evalPyHTML-if: datetime.datetime.now().second%2==0}}></b><{{evalPyHTML-else}}></i><{{evalPyHTML-endif}}>
		</p>
	</body>
</html>